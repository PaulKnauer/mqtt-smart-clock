#pragma once

// Copy this file to credentials.h and fill in your values.
// credentials.h is gitignored — never commit it.

namespace credentials {

constexpr char kWifiSsid[]     = "YOUR_WIFI_SSID";
constexpr char kWifiPassword[] = "YOUR_WIFI_PASSWORD";

// MQTT broker connection. Default: plain TCP on port 1883 for home network.
// For TLS: change to "mqtts://broker.local" and port 8883, set kMqttCaCert.
constexpr char kMqttBrokerHost[] = "192.168.1.100";
constexpr uint16_t kMqttPort     = 1883;
constexpr char kMqttUsername[]   = "";
constexpr char kMqttPassword[]   = "";

// Optional: PEM-encoded CA certificate for TLS broker verification.
// Set to nullptr to skip server certificate validation (insecure; local dev only).
constexpr const char* kMqttCaCert = nullptr;

}  // namespace credentials
